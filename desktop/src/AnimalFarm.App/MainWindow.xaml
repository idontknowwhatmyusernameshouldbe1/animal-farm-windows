<Window x:Class="AnimalFarm.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        Height="820"
        Width="1100"
        MinHeight="640"
        MinWidth="760"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgBaseBrush}"
        FontFamily="{StaticResource BodyFont}">
    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource HeaderBrush}"
                BorderBrush="{DynamicResource LineBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,16">
            <DockPanel LastChildFill="False">
                <Button DockPanel.Dock="Left"
                        Content="{Binding Localization.T.Brand}"
                        Command="{Binding GoHomeCommand}"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        FontFamily="{StaticResource DisplayFont}"
                        FontSize="22"
                        FontWeight="Bold"
                        Foreground="{DynamicResource InkBrush}"
                        Padding="0" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Style="{StaticResource LangButton}"
                            Content="{Binding ThemeToggleLabel}"
                            ToolTip="{Binding ThemeToggleAria}"
                            Command="{Binding ToggleThemeCommand}" />
                    <Button Style="{StaticResource LangButton}"
                            Content="{Binding Localization.T.LangToggle}"
                            ToolTip="{Binding Localization.T.LangToggleAria}"
                            Command="{Binding ToggleLanguageCommand}"
                            Margin="0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Frame x:Name="RootFrame"
               Grid.Row="1"
               NavigationUIVisibility="Hidden"
               JournalOwnership="OwnsJournal" />
    </Grid>
</Window>
