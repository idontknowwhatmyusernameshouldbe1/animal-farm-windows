<Page x:Class="AnimalFarm.App.Views.PetFormPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,24,28,40">
        <StackPanel MaxWidth="640" HorizontalAlignment="Center">
            <TextBlock Text="{Binding Title}"
                       FontFamily="{StaticResource DisplayFont}"
                       FontSize="36"
                       FontWeight="Bold"
                       Foreground="{StaticResource InkBrush}"
                       TextWrapping="Wrap" />
            <TextBlock Text="{Binding Subtitle}"
                       FontSize="16"
                       Foreground="{StaticResource MutedBrush}"
                       TextWrapping="Wrap"
                       Margin="0,8,0,28" />

            <TextBlock Style="{StaticResource FieldLabel}" Text="{Binding Localization.T.Photo}" />
            <Button Command="{Binding ChoosePhotoCommand}"
                    Margin="0,0,0,20"
                    Cursor="Hand"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    HorizontalContentAlignment="Stretch">
                <Border Background="{StaticResource SurfaceStrongBrush}"
                        BorderBrush="{StaticResource LineBrush}"
                        BorderThickness="1"
                        CornerRadius="18"
                        MinHeight="220"
                        ClipToBounds="True">
                    <Grid>
                        <StackPanel VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Margin="24"
                                    Visibility="{Binding HasPreview, Converter={StaticResource NullToCollapsed}}">
                            <TextBlock Text="{Binding Localization.T.PhotoHintTitle}"
                                       FontWeight="SemiBold"
                                       FontSize="16"
                                       Foreground="{StaticResource InkBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding Localization.T.PhotoHintBody}"
                                       Foreground="{StaticResource MutedBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,6,0,0" />
                        </StackPanel>
                        <Image Source="{Binding PreviewImage}"
                               Stretch="UniformToFill"
                               Visibility="{Binding HasPreview, Converter={StaticResource NullToVisibility}}" />
                    </Grid>
                </Border>
            </Button>

            <TextBlock Style="{StaticResource FieldLabel}" Text="{Binding Localization.T.Name}" />
            <TextBox Style="{StaticResource TextField}"
                     Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                     MaxLength="80"
                     Margin="0,0,0,16" />

            <TextBlock Style="{StaticResource FieldLabel}" Text="{Binding Localization.T.Description}" />
            <TextBox Style="{StaticResource TextField}"
                     Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     Height="140"
                     VerticalContentAlignment="Top"
                     MaxLength="2000"
                     Margin="0,0,0,12" />

            <TextBlock Text="{Binding Error}"
                       Foreground="{StaticResource DangerBrush}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,16"
                       Visibility="{Binding Error, Converter={StaticResource NullToVisibility}}" />

            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource PrimaryButton}"
                        Content="{Binding SaveLabel}"
                        Command="{Binding SaveCommand}"
                        IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBool}}"
                        Margin="0,0,12,0" />
                <Button Style="{StaticResource SecondaryButton}"
                        Content="{Binding Localization.T.Cancel}"
                        Command="{Binding CancelCommand}"
                        IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBool}}" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
