<Page x:Class="AnimalFarm.App.Views.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:AnimalFarm.App.ViewModels"
      Background="Transparent"
      Title="{Binding Localization.T.Brand}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,24,28,40">
        <StackPanel MaxWidth="980" HorizontalAlignment="Center">
            <TextBlock Text="{Binding Localization.T.Brand}"
                       FontFamily="{StaticResource DisplayFont}"
                       FontSize="56"
                       FontWeight="Bold"
                       Foreground="{DynamicResource InkBrush}"
                       Margin="0,12,0,8" />
            <TextBlock Text="{Binding Localization.T.HeroCopy}"
                       FontSize="18"
                       Foreground="{DynamicResource MutedBrush}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,20"
                       MaxWidth="520"
                       HorizontalAlignment="Left" />
            <Button Style="{StaticResource PrimaryButton}"
                    Content="{Binding Localization.T.AddPet}"
                    Command="{Binding AddPetCommand}"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,36" />

            <TextBlock Text="{Binding Localization.T.GalleryLabel}"
                       FontFamily="{StaticResource DisplayFont}"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource InkSoftBrush}"
                       Margin="0,0,0,16" />

            <Border Visibility="{Binding IsEmpty, Converter={StaticResource NullToVisibility}}"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource LineBrush}"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="28,24"
                    Margin="0,4,0,0">
                <StackPanel>
                    <TextBlock Text="{Binding Localization.T.EmptyFarm}"
                               FontSize="16"
                               Foreground="{DynamicResource MutedBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,16" />
                    <Button Style="{StaticResource PrimaryButton}"
                            Content="{Binding Localization.T.AddPet}"
                            Command="{Binding AddPetCommand}"
                            HorizontalAlignment="Left" />
                </StackPanel>
            </Border>

            <ItemsControl ItemsSource="{Binding Pets}"
                          Visibility="{Binding HasPets, Converter={StaticResource NullToVisibility}}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:PetCardViewModel}">
                        <Button Width="240"
                                Margin="0,0,16,16"
                                Padding="0"
                                BorderThickness="0"
                                Cursor="Hand"
                                Background="Transparent"
                                Command="{Binding DataContext.OpenPetCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                CommandParameter="{Binding}">
                            <Border Background="{DynamicResource SurfaceStrongBrush}"
                                    CornerRadius="18"
                                    BorderBrush="{DynamicResource LineBrush}"
                                    BorderThickness="1"
                                    ClipToBounds="True">
                                <Grid Width="240" Height="300">
                                    <Border Background="{DynamicResource ImageFallbackBrush}">
                                        <Image Source="{Binding Image}" Stretch="UniformToFill" />
                                    </Border>
                                    <Border VerticalAlignment="Bottom">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                <GradientStop Color="#00000000" Offset="0" />
                                                <GradientStop Color="#CC0B1018" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <TextBlock Text="{Binding Name}"
                                                   FontWeight="SemiBold"
                                                   FontSize="17"
                                                   Foreground="White"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="14,28,14,14" />
                                    </Border>
                                </Grid>
                            </Border>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</Page>
