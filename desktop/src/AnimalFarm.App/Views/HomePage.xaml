<Page x:Class="AnimalFarm.App.Views.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:AnimalFarm.App.ViewModels"
      Background="Transparent"
      Title="{Binding Localization.T.Brand}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,24,28,40">
        <StackPanel MaxWidth="980" HorizontalAlignment="Center">
            <TextBlock Text="{Binding Localization.T.Brand}"
                       FontFamily="{StaticResource DisplayFont}"
                       FontSize="56"
                       FontWeight="Bold"
                       Foreground="{StaticResource InkBrush}"
                       Margin="0,12,0,8" />
            <TextBlock Text="{Binding Localization.T.HeroCopy}"
                       FontSize="18"
                       Foreground="{StaticResource MutedBrush}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,20"
                       MaxWidth="520"
                       HorizontalAlignment="Left" />
            <Button Style="{StaticResource PrimaryButton}"
                    Content="{Binding Localization.T.AddPet}"
                    Command="{Binding AddPetCommand}"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,36" />

            <TextBlock Text="{Binding Localization.T.GalleryLabel}"
                       FontFamily="{StaticResource DisplayFont}"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource InkSoftBrush}"
                       Margin="0,0,0,16" />

            <TextBlock Text="{Binding Localization.T.EmptyFarm}"
                       FontSize="16"
                       Foreground="{StaticResource MutedBrush}"
                       TextWrapping="Wrap"
                       Visibility="{Binding IsEmpty, Converter={StaticResource NullToVisibility}}"
                       Margin="0,8,0,0" />

            <ItemsControl ItemsSource="{Binding Pets}"
                          Visibility="{Binding HasPets, Converter={StaticResource NullToVisibility}}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:PetCardViewModel}">
                        <Button Width="280"
                                Margin="0,0,16,16"
                                Padding="0"
                                BorderThickness="0"
                                Cursor="Hand"
                                Background="Transparent"
                                Command="{Binding DataContext.OpenPetCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                CommandParameter="{Binding}">
                            <Border Background="{StaticResource SurfaceStrongBrush}"
                                    CornerRadius="18"
                                    BorderBrush="{StaticResource LineBrush}"
                                    BorderThickness="1"
                                    ClipToBounds="True">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="220" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="{StaticResource ImageFallbackBrush}">
                                        <Image Source="{Binding Image}" Stretch="UniformToFill" />
                                    </Border>
                                    <StackPanel Grid.Row="1" Margin="14,12,14,14">
                                        <TextBlock Text="{Binding Name}"
                                                   FontWeight="SemiBold"
                                                   FontSize="17"
                                                   Foreground="{StaticResource InkBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Description}"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   FontSize="13"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxHeight="36"
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</Page>
